<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.canvas.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.transform.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.snappark.controller.KioskWelcomeController"
           fx:id="rootPane"
           style="-fx-background-color:#05080F;">
    <Canvas fx:id="bgCanvas"/>
    <BorderPane>
        <center>
            <VBox alignment="CENTER" spacing="12" style="-fx-padding:24 40 24 40;">

                <!-- Logo / Title -->
                <VBox alignment="CENTER" spacing="4" onMouseClicked="#handleLogoClick" style="-fx-cursor:hand;">
                    <Label text="🅿️"
                           style="-fx-text-fill:#00C2FF;-fx-font-size:56px;-fx-font-weight:bold;"/>
                    <Label text="SnapPark"
                           style="-fx-text-fill:white;-fx-font-size:34px;-fx-font-weight:bold;-fx-font-family:monospace;-fx-effect:dropshadow(gaussian,#00C2FF,12,0.4,0,0);"/>
                    <Label text="Smart Parking System"
                           style="-fx-text-fill:#334155;-fx-font-size:12px;-fx-font-family:monospace;"/>
                </VBox>

                <!-- Greeting + Context -->
                <Label fx:id="greetingLabel" text=""
                       style="-fx-font-size:16px;-fx-font-family:monospace;-fx-font-weight:bold;"/>
                <Label fx:id="contextLabel" text=""
                       style="-fx-text-fill:#64748b;-fx-font-family:monospace;-fx-font-size:11px;"/>
                <Label fx:id="surgeLabel" text="" visible="false" managed="false"
                       style="-fx-font-family:monospace;-fx-font-size:10px;-fx-font-weight:bold;"/>

                <!-- QR Codes: Entry + Exit side-by-side -->
                <HBox alignment="CENTER" spacing="80" style="-fx-padding:8 0 8 0;">
                    <!-- Entry QR -->
                    <VBox alignment="CENTER" spacing="6"
                          style="-fx-background-color:#0D1117;-fx-background-radius:16;-fx-border-color:#00FF88;-fx-border-radius:16;-fx-border-width:1;-fx-padding:20 30 20 30;-fx-effect:dropshadow(gaussian,#00FF88,18,0.3,0,0);">
                        <Label text="📲 SCAN TO PARK"
                               style="-fx-text-fill:#00FF88;-fx-font-size:14px;-fx-font-weight:bold;-fx-font-family:monospace;"/>
                        <ImageView fx:id="entryQrImage" fitWidth="200" fitHeight="200" preserveRatio="true"/>
                        <Label fx:id="entryUrlLabel" text=""
                               style="-fx-text-fill:#484F58;-fx-font-size:9px;-fx-font-family:monospace;" wrapText="true" maxWidth="180" alignment="CENTER"/>
                    </VBox>

                    <!-- Exit QR -->
                    <VBox alignment="CENTER" spacing="6"
                          style="-fx-background-color:#0D1117;-fx-background-radius:16;-fx-border-color:#FF2244;-fx-border-radius:16;-fx-border-width:1;-fx-padding:20 30 20 30;-fx-effect:dropshadow(gaussian,#FF2244,18,0.3,0,0);">
                        <Label text="📲 SCAN TO LEAVE"
                               style="-fx-text-fill:#FF2244;-fx-font-size:14px;-fx-font-weight:bold;-fx-font-family:monospace;"/>
                        <ImageView fx:id="exitQrImage" fitWidth="200" fitHeight="200" preserveRatio="true"/>
                        <Label fx:id="exitUrlLabel" text=""
                               style="-fx-text-fill:#484F58;-fx-font-size:9px;-fx-font-family:monospace;" wrapText="true" maxWidth="180" alignment="CENTER"/>
                    </VBox>
                </HBox>

                <!-- Stats bar -->
                <HBox alignment="CENTER" spacing="28">
                    <Label fx:id="slotsLabel" text="Loading..."
                           style="-fx-text-fill:#00FF88;-fx-font-size:13px;-fx-font-family:monospace;-fx-background-color:#0A1A0A;-fx-background-radius:22;-fx-border-color:#00FF88;-fx-border-radius:22;-fx-border-width:1;-fx-padding:6 18 6 18;"/>
                    <Label fx:id="ratesLabel" text=""
                           style="-fx-text-fill:#FFB800;-fx-font-size:13px;-fx-font-family:monospace;-fx-background-color:#1A1200;-fx-background-radius:22;-fx-border-color:#FFB800;-fx-border-radius:22;-fx-border-width:1;-fx-padding:6 18 6 18;"/>
                    <Label fx:id="clockLabel" text="00:00:00"
                           style="-fx-text-fill:#00C2FF;-fx-font-size:13px;-fx-font-family:monospace;-fx-background-color:#0A0F1A;-fx-background-radius:22;-fx-border-color:#00C2FF;-fx-border-radius:22;-fx-border-width:1;-fx-padding:6 18 6 18;"/>
                </HBox>

                <!-- EXIT PIN VERIFICATION -->
                <VBox alignment="CENTER" spacing="8"
                      style="-fx-background-color:#0D1117;-fx-background-radius:16;-fx-border-color:#21262D;-fx-border-radius:16;-fx-border-width:1;-fx-padding:16 30 16 30;">
                    <Label text="EXIT VERIFICATION — Enter 6-digit PIN"
                           style="-fx-text-fill:#8B949E;-fx-font-size:11px;-fx-font-family:monospace;-fx-font-weight:bold;-fx-letter-spacing:1;"/>
                    <TextField fx:id="exitPinField"
                               promptText="● ● ● ● ● ●"
                               maxWidth="280"
                               alignment="CENTER"
                               style="-fx-background-color:#161B22;-fx-text-fill:#00C2FF;-fx-font-size:28px;-fx-font-family:monospace;-fx-font-weight:bold;-fx-background-radius:10;-fx-border-color:#21262D;-fx-border-radius:10;-fx-border-width:1;-fx-alignment:center;-fx-padding:10;"/>
                    <HBox alignment="CENTER" spacing="6">
                        <Button text="VERIFY ✓" onAction="#handleVerifyPin"
                                style="-fx-min-width:120;-fx-min-height:36;-fx-font-size:13px;-fx-font-weight:bold;-fx-font-family:monospace;-fx-background-color:#002B18;-fx-text-fill:#00FF88;-fx-background-radius:8;-fx-border-color:#00FF88;-fx-border-radius:8;-fx-border-width:1;-fx-cursor:hand;"/>
                        <Button text="CLEAR" onAction="#handleClearPin"
                                style="-fx-min-width:80;-fx-min-height:36;-fx-font-size:11px;-fx-font-weight:bold;-fx-font-family:monospace;-fx-background-color:#161B22;-fx-text-fill:#8B949E;-fx-background-radius:8;-fx-border-color:#21262D;-fx-border-radius:8;-fx-border-width:1;-fx-cursor:hand;"/>
                    </HBox>
                    <Label fx:id="verifyStatus" text=""
                           style="-fx-font-size:12px;-fx-font-family:monospace;-fx-font-weight:bold;"/>
                </VBox>

                <Label text="Tap logo 3× for admin"
                       style="-fx-text-fill:#1A2A3A;-fx-font-size:10px;-fx-font-family:monospace;"/>

            </VBox>
        </center>
    </BorderPane>

    <!-- Barrier Animation Overlay -->
    <Pane fx:id="barrierPane" visible="false" mouseTransparent="true"
          style="-fx-background-color:rgba(5,8,15,0.75);">
        <!-- Barrier base/post -->
        <Rectangle x="200" y="300" width="16" height="120"
                   fill="#21262D" arcWidth="4" arcHeight="4"
                   stroke="#334155" strokeWidth="1"/>
        <!-- Barrier arm (rotates around pivot) -->
        <Rectangle fx:id="barrierArm" x="208" y="298" width="260" height="10"
                   fill="#FFB800" arcWidth="4" arcHeight="4"
                   stroke="#CC9200" strokeWidth="1"
                   style="-fx-effect:dropshadow(gaussian,#FFB800,12,0.5,0,0);">
            <transforms>
                <javafx.scene.transform.Rotate pivotX="208" pivotY="303" angle="0"/>
            </transforms>
        </Rectangle>
        <!-- Pivot circle -->
        <Circle fx:id="barrierPivot" centerX="208" centerY="303" radius="10"
                fill="#161B22" stroke="#334155" strokeWidth="2"/>
        <!-- Status light -->
        <Circle fx:id="barrierLight" centerX="208" centerY="380" radius="14"
                fill="#FF2244" stroke="#21262D" strokeWidth="2"
                style="-fx-effect:dropshadow(gaussian,#FF2244,16,0.6,0,0);"/>
        <!-- Label -->
        <Label layoutX="180" layoutY="410"
               text="EXIT BARRIER"
               style="-fx-text-fill:#8B949E;-fx-font-size:11px;-fx-font-family:monospace;-fx-font-weight:bold;"/>
    </Pane>
</StackPane>
