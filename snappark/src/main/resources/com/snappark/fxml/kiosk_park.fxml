<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.snappark.controller.KioskParkController"
           fx:id="rootPane" style="-fx-background-color:#05080F;" minWidth="99999" minHeight="99999">

  <!-- ═══ STEP 1 ═══════════════════════════════════════════════ -->
  <VBox fx:id="step1" spacing="0" maxWidth="Infinity" prefWidth="99999">

    <!-- TOP BAR -->
    <HBox alignment="CENTER_LEFT" spacing="8"
          minHeight="46" maxHeight="46"
          style="-fx-background-color:#0A0F1A;-fx-border-color:#00C2FF;
                 -fx-border-width:0 0 2 0;-fx-padding:0 12 0 12;">
      <Button text="BACK" onAction="#handleBack"
              style="-fx-background-color:#0D1525;-fx-text-fill:#64748b;
                     -fx-font-family:monospace;-fx-font-size:11px;-fx-cursor:hand;
                     -fx-border-color:#334155;-fx-border-width:1;
                     -fx-background-radius:4;-fx-border-radius:4;-fx-padding:4 10 4 10;"/>
      <Label text="1/3" style="-fx-text-fill:#334155;-fx-font-family:monospace;-fx-font-size:11px;"/>
      <Label text="SELECT SLOT"
             style="-fx-text-fill:#00C2FF;-fx-font-size:14px;
                    -fx-font-weight:bold;-fx-font-family:monospace;"/>
      <Pane HBox.hgrow="ALWAYS"/>
      <Button fx:id="btnAll"  text="ALL"       onAction="#filterAll"
              style="-fx-background-color:#00C2FF;-fx-text-fill:#0A0F1A;
                     -fx-font-family:monospace;-fx-font-size:11px;-fx-font-weight:bold;
                     -fx-cursor:hand;-fx-background-radius:4;-fx-padding:4 10 4 10;"/>
      <Button fx:id="btnTwo"  text="2-WHEELER" onAction="#filterTwo"
              style="-fx-background-color:#0D1525;-fx-text-fill:#00FF88;
                     -fx-border-color:#00FF88;-fx-border-width:1;
                     -fx-font-family:monospace;-fx-font-size:11px;-fx-cursor:hand;
                     -fx-background-radius:4;-fx-border-radius:4;-fx-padding:4 10 4 10;"/>
      <Button fx:id="btnFour" text="4-WHEELER" onAction="#filterFour"
              style="-fx-background-color:#0D1525;-fx-text-fill:#00C2FF;
                     -fx-border-color:#00C2FF;-fx-border-width:1;
                     -fx-font-family:monospace;-fx-font-size:11px;-fx-cursor:hand;
                     -fx-background-radius:4;-fx-border-radius:4;-fx-padding:4 10 4 10;"/>
      <ComboBox fx:id="floorBox"
                style="-fx-background-color:#0D1525;-fx-border-color:#1E3A5F;
                       -fx-border-width:1;-fx-font-family:monospace;
                       -fx-font-size:11px;-fx-min-width:80px;"/>
    </HBox>

    <!-- AI RECOMMENDATION BAR -->
    <HBox style="-fx-background-color:#0D1020;-fx-border-color:#FFD700;
                 -fx-border-width:0 0 1 0;-fx-padding:4 12 4 12;"
          spacing="8" alignment="CENTER_LEFT" minHeight="26" maxHeight="26">
      <Label text="AI BEST:"
             style="-fx-text-fill:#FFD700;-fx-font-family:monospace;
                    -fx-font-size:10px;-fx-font-weight:bold;"/>
      <Label fx:id="rec1Label"    text=""
             style="-fx-text-fill:#FFD700;-fx-font-family:monospace;
                    -fx-font-size:11px;-fx-font-weight:bold;"/>
      <Label fx:id="rec2Label"    text=""
             style="-fx-text-fill:#64748b;-fx-font-family:monospace;-fx-font-size:10px;"/>
      <Label fx:id="rec3Label"    text=""
             style="-fx-text-fill:#64748b;-fx-font-family:monospace;-fx-font-size:10px;"/>
      <Pane HBox.hgrow="ALWAYS"/>
      <Label fx:id="recScoreLabel" text=""
             style="-fx-text-fill:#FFD700;-fx-font-family:monospace;-fx-font-size:10px;"/>
    </HBox>

    <!-- STATUS BAR -->
    <Label fx:id="step1Status" text="Tap a GREEN slot to select it"
           minHeight="22" maxHeight="22"
           style="-fx-text-fill:#FFB800;-fx-font-family:monospace;
                  -fx-font-size:11px;-fx-padding:0 12 0 12;
                  -fx-background-color:#070B10;"/>

    <!-- MAIN 3-COLUMN BODY -->
    <HBox VBox.vgrow="ALWAYS" spacing="0">

      <!-- LEFT COLUMN — 2 independent boxes -->
      <VBox minWidth="185" maxWidth="185" spacing="0">

        <!-- BOX 1: HOW IT WORKS -->
        <VBox fx:id="howItWorksBox" VBox.vgrow="ALWAYS"
              style="-fx-background-color:#0D1525;
                     -fx-border-color:#00C2FF;-fx-border-width:0 1 1 0;
                     -fx-padding:12 12 12 12;">
          <Label text="[ HOW IT WORKS ]"
                 style="-fx-text-fill:#00C2FF;-fx-font-family:monospace;
                        -fx-font-size:11px;-fx-font-weight:bold;-fx-padding:0 0 8 0;"/>
        </VBox>

        <!-- BOX 2: SAFETY TIPS -->
        <VBox fx:id="safetyTipsBox" VBox.vgrow="ALWAYS"
              style="-fx-background-color:#0D1525;
                     -fx-border-color:#00FF88;-fx-border-width:0 1 0 0;
                     -fx-padding:12 12 12 12;">
          <Label text="[ SAFETY TIPS ]"
                 style="-fx-text-fill:#00FF88;-fx-font-family:monospace;
                        -fx-font-size:11px;-fx-font-weight:bold;-fx-padding:0 0 8 0;"/>
        </VBox>

      </VBox>

      <!-- CENTRE — 3D GRID -->
      <StackPane fx:id="gridContainer" HBox.hgrow="ALWAYS"
                 style="-fx-background-color:#05080F;"/>

      <!-- RIGHT COLUMN — 2 independent boxes -->
      <VBox minWidth="185" maxWidth="185" spacing="0">

        <!-- BOX 3: RATES + RULES -->
        <VBox fx:id="ratesBox" VBox.vgrow="ALWAYS"
              style="-fx-background-color:#0D1525;
                     -fx-border-color:#FFB800;-fx-border-width:0 0 1 1;
                     -fx-padding:12 12 12 12;">
          <Label text="[ RATES + RULES ]"
                 style="-fx-text-fill:#FFB800;-fx-font-family:monospace;
                        -fx-font-size:11px;-fx-font-weight:bold;-fx-padding:0 0 8 0;"/>
        </VBox>

        <!-- BOX 4: GRID LEGEND -->
        <VBox fx:id="legendBox" VBox.vgrow="ALWAYS"
              style="-fx-background-color:#0D1525;
                     -fx-border-color:#A855F7;-fx-border-width:0 0 0 1;
                     -fx-padding:12 12 12 12;">
          <Label text="[ GRID LEGEND ]"
                 style="-fx-text-fill:#A855F7;-fx-font-family:monospace;
                        -fx-font-size:11px;-fx-font-weight:bold;-fx-padding:0 0 8 0;"/>
        </VBox>

      </VBox>
    </HBox>
  </VBox>

  <!-- NEXT BAR overlay -->
  <HBox fx:id="step1NextBar" visible="false" managed="false"
        alignment="CENTER_RIGHT" spacing="12"
        minHeight="54" maxHeight="54"
        StackPane.alignment="BOTTOM_CENTER"
        style="-fx-background-color:#0A0F1A;-fx-border-color:#00FF88;
               -fx-border-width:2 0 0 0;-fx-padding:0 16 0 16;">
    <Label fx:id="selectedSlotInfo" text=""
           style="-fx-text-fill:#00FF88;-fx-font-family:monospace;
                  -fx-font-size:13px;-fx-font-weight:bold;"/>
    <Pane HBox.hgrow="ALWAYS"/>
    <Button text="NEXT  —  ENTER DETAILS" onAction="#handleStep1Next"
            style="-fx-background-color:#00FF88;-fx-text-fill:#0A1A0A;
                   -fx-font-size:15px;-fx-font-weight:bold;-fx-font-family:monospace;
                   -fx-background-radius:8;-fx-border-radius:8;
                   -fx-cursor:hand;-fx-padding:10 24 10 24;"/>
  </HBox>

  <!-- ═══ STEP 2 ═══════════════════════════════════════════════ -->
  <VBox fx:id="step2" visible="false" managed="false">
    <HBox alignment="CENTER_LEFT" spacing="8" minHeight="48" maxHeight="48"
          style="-fx-background-color:#0A0F1A;-fx-border-color:#00C2FF;
                 -fx-border-width:0 0 2 0;-fx-padding:0 12 0 12;">
      <Button text="BACK" onAction="#handleStep2Back"
              style="-fx-background-color:#0D1525;-fx-text-fill:#64748b;
                     -fx-font-family:monospace;-fx-font-size:11px;-fx-cursor:hand;
                     -fx-border-color:#334155;-fx-border-width:1;
                     -fx-background-radius:4;-fx-border-radius:4;-fx-padding:4 10 4 10;"/>
      <Label text="2/3" style="-fx-text-fill:#334155;-fx-font-family:monospace;-fx-font-size:11px;"/>
      <Label text="ENTER YOUR DETAILS"
             style="-fx-text-fill:#00C2FF;-fx-font-size:14px;
                    -fx-font-weight:bold;-fx-font-family:monospace;"/>
    </HBox>
    <StackPane VBox.vgrow="ALWAYS" alignment="CENTER"
               style="-fx-background-color:#05080F;">
      <VBox spacing="12" alignment="CENTER" maxWidth="480"
            style="-fx-padding:20;">
        <VBox alignment="CENTER" spacing="4"
              style="-fx-background-color:#0D1525;-fx-background-radius:10;
                     -fx-border-color:#00C2FF;-fx-border-radius:10;
                     -fx-border-width:1;-fx-padding:10;">
          <Label text="SELECTED SLOT"
                 style="-fx-text-fill:#64748b;-fx-font-family:monospace;-fx-font-size:10px;"/>
          <Label fx:id="slotNumLabel" text=""
                 style="-fx-text-fill:#00C2FF;-fx-font-size:26px;
                        -fx-font-weight:bold;-fx-font-family:monospace;"/>
          <Label fx:id="slotTypeLabel" text=""
                 style="-fx-text-fill:#64748b;-fx-font-family:monospace;-fx-font-size:11px;"/>
        </VBox>
        <VBox spacing="4">
          <Label text="FULL NAME"
                 style="-fx-text-fill:#94a3b8;-fx-font-size:11px;-fx-font-family:monospace;"/>
          <TextField fx:id="nameField" promptText="Enter your full name"
                     style="-fx-background-color:#0D1525;-fx-text-fill:white;
                            -fx-border-color:#1E3A5F;-fx-border-radius:8;
                            -fx-background-radius:8;-fx-border-width:1;
                            -fx-padding:11;-fx-font-size:15px;"/>
        </VBox>
        <VBox spacing="4">
          <Label text="LICENSE PLATE"
                 style="-fx-text-fill:#94a3b8;-fx-font-size:11px;-fx-font-family:monospace;"/>
          <TextField fx:id="plateField" promptText="e.g. MH12AB1234"
                     style="-fx-background-color:#0D1525;-fx-text-fill:white;
                            -fx-border-color:#1E3A5F;-fx-border-radius:8;
                            -fx-background-radius:8;-fx-border-width:1;
                            -fx-padding:11;-fx-font-size:15px;-fx-font-family:monospace;"/>
          <HBox fx:id="decoderBox" spacing="10" alignment="CENTER_LEFT"
                visible="false" managed="false"
                style="-fx-background-color:#080C14;-fx-background-radius:8;
                       -fx-border-radius:8;-fx-border-width:1;
                       -fx-border-color:#1E3A5F;-fx-padding:7 12 7 12;">
            <Label fx:id="stateDot" text="  "
                   style="-fx-background-color:#334155;-fx-min-width:14;
                          -fx-min-height:14;-fx-background-radius:7;"/>
            <Label fx:id="decoderState" text=""
                   style="-fx-text-fill:#00C2FF;-fx-font-family:monospace;
                          -fx-font-size:12px;-fx-font-weight:bold;"/>
            <Label text="|" style="-fx-text-fill:#1E3A5F;"/>
            <Label fx:id="decoderRTO" text=""
                   style="-fx-text-fill:#94a3b8;-fx-font-family:monospace;-fx-font-size:11px;"/>
            <Pane HBox.hgrow="ALWAYS"/>
            <Label fx:id="decoderValid" text=""
                   style="-fx-text-fill:#00FF88;-fx-font-family:monospace;
                          -fx-font-size:12px;-fx-font-weight:bold;"/>
          </HBox>
          <Label fx:id="decoderError" text="" visible="false" managed="false"
                 style="-fx-text-fill:#FF2244;-fx-font-family:monospace;-fx-font-size:11px;"/>
        </VBox>
        <VBox spacing="4">
          <HBox spacing="8" alignment="CENTER_LEFT">
            <Label text="MOBILE NUMBER"
                   style="-fx-text-fill:#94a3b8;-fx-font-size:11px;-fx-font-family:monospace;"/>
            <Label text="(PIN will be sent here)"
                   style="-fx-text-fill:#7C3AED;-fx-font-size:10px;-fx-font-family:monospace;"/>
          </HBox>
          <HBox spacing="0">
            <Label text="+91"
                   style="-fx-text-fill:#00C2FF;-fx-font-family:monospace;
                          -fx-font-size:15px;-fx-font-weight:bold;
                          -fx-background-color:#0D1525;
                          -fx-border-color:#1E3A5F;-fx-border-width:1 0 1 1;
                          -fx-background-radius:8 0 0 8;-fx-border-radius:8 0 0 8;
                          -fx-padding:11 10 11 12;"/>
            <TextField fx:id="phoneField" promptText="10-digit mobile"
                       HBox.hgrow="ALWAYS"
                       style="-fx-background-color:#0D1525;-fx-text-fill:white;
                              -fx-border-color:#1E3A5F;
                              -fx-border-radius:0 8 8 0;-fx-background-radius:0 8 8 0;
                              -fx-border-width:1;-fx-padding:11;
                              -fx-font-size:15px;-fx-font-family:monospace;"/>
          </HBox>
          <Label fx:id="phoneError" text="" visible="false" managed="false"
                 style="-fx-text-fill:#FF2244;-fx-font-family:monospace;-fx-font-size:11px;"/>
        </VBox>
        <Label fx:id="step2Error" text=""
               style="-fx-text-fill:#FF2244;-fx-font-family:monospace;-fx-font-size:12px;"/>
        <Button text="CONFIRM BOOKING" onAction="#handleConfirmBooking"
                maxWidth="Infinity"
                style="-fx-background-color:#00FF88;-fx-text-fill:#0A1A0A;
                       -fx-font-size:16px;-fx-font-weight:bold;-fx-font-family:monospace;
                       -fx-background-radius:10;-fx-cursor:hand;-fx-min-height:52;"/>
      </VBox>
    </StackPane>
  </VBox>

  <!-- ═══ STEP 3 ═══════════════════════════════════════════════ -->
  <VBox fx:id="step3" visible="false" managed="false">
    <HBox alignment="CENTER_LEFT" spacing="8" minHeight="48" maxHeight="48"
          style="-fx-background-color:#0A0F1A;-fx-border-color:#00FF88;
                 -fx-border-width:0 0 2 0;-fx-padding:0 12 0 12;">
      <Label text="3/3"
             style="-fx-text-fill:#334155;-fx-font-family:monospace;-fx-font-size:11px;"/>
      <Label text="BOOKING CONFIRMED!"
             style="-fx-text-fill:#00FF88;-fx-font-size:14px;
                    -fx-font-weight:bold;-fx-font-family:monospace;"/>
      <Pane HBox.hgrow="ALWAYS"/>
      <Label fx:id="cdLabel" text=""
             style="-fx-text-fill:#64748b;-fx-font-family:monospace;-fx-font-size:11px;"/>
    </HBox>
    <StackPane VBox.vgrow="ALWAYS" alignment="CENTER"
               style="-fx-background-color:#05080F;">
      <HBox spacing="28" alignment="CENTER" style="-fx-padding:20;">
        <VBox alignment="CENTER" spacing="10"
              style="-fx-background-color:#0D1525;-fx-background-radius:14;
                     -fx-border-color:#00FF88;-fx-border-radius:14;
                     -fx-border-width:1;-fx-padding:20;">
          <Label text="YOUR TICKET QR"
                 style="-fx-text-fill:#00FF88;-fx-font-family:monospace;
                        -fx-font-size:11px;-fx-font-weight:bold;"/>
          <ImageView fx:id="qrView" fitWidth="190" fitHeight="190"
                     preserveRatio="true"/>
          <Label text="Show this at exit"
                 style="-fx-text-fill:#64748b;-fx-font-family:monospace;-fx-font-size:10px;"/>
        </VBox>
        <VBox spacing="10" HBox.hgrow="ALWAYS" maxWidth="360"
              style="-fx-background-color:#0D1525;-fx-background-radius:14;
                     -fx-border-color:#00C2FF;-fx-border-radius:14;
                     -fx-border-width:1;-fx-padding:20;">
          <Label text="TICKET DETAILS"
                 style="-fx-text-fill:#00C2FF;-fx-font-family:monospace;
                        -fx-font-size:11px;-fx-font-weight:bold;"/>
          <HBox><Label text="Ticket : " style="-fx-text-fill:#64748b;-fx-font-family:monospace;-fx-min-width:90;-fx-font-size:12px;"/>
                <Label fx:id="tktId" style="-fx-text-fill:#00FF88;-fx-font-size:18px;-fx-font-weight:bold;-fx-font-family:monospace;"/></HBox>
          <HBox><Label text="Name   : " style="-fx-text-fill:#64748b;-fx-font-family:monospace;-fx-min-width:90;-fx-font-size:12px;"/>
                <Label fx:id="tktName" style="-fx-text-fill:white;-fx-font-family:monospace;-fx-font-size:12px;"/></HBox>
          <HBox><Label text="Plate  : " style="-fx-text-fill:#64748b;-fx-font-family:monospace;-fx-min-width:90;-fx-font-size:12px;"/>
                <Label fx:id="tktPlate" style="-fx-text-fill:white;-fx-font-family:monospace;-fx-font-size:12px;"/></HBox>
          <HBox><Label text="Slot   : " style="-fx-text-fill:#64748b;-fx-font-family:monospace;-fx-min-width:90;-fx-font-size:12px;"/>
                <Label fx:id="tktSlot" style="-fx-text-fill:#00C2FF;-fx-font-weight:bold;-fx-font-family:monospace;-fx-font-size:12px;"/></HBox>
          <HBox><Label text="Type   : " style="-fx-text-fill:#64748b;-fx-font-family:monospace;-fx-min-width:90;-fx-font-size:12px;"/>
                <Label fx:id="tktType" style="-fx-text-fill:white;-fx-font-family:monospace;-fx-font-size:12px;"/></HBox>
          <HBox><Label text="Entry  : " style="-fx-text-fill:#64748b;-fx-font-family:monospace;-fx-min-width:90;-fx-font-size:12px;"/>
                <Label fx:id="tktTime" style="-fx-text-fill:#FFB800;-fx-font-family:monospace;-fx-font-size:12px;"/></HBox>
          <HBox><Label text="Mobile : " style="-fx-text-fill:#64748b;-fx-font-family:monospace;-fx-min-width:90;-fx-font-size:12px;"/>
                <Label fx:id="tktPhone" style="-fx-text-fill:#7C3AED;-fx-font-family:monospace;-fx-font-size:12px;"/></HBox>
          <Button text="DONE - GO HOME" onAction="#handleDone" maxWidth="Infinity"
                  style="-fx-background-color:#00FF88;-fx-text-fill:#0A1A0A;
                         -fx-font-size:14px;-fx-font-weight:bold;-fx-font-family:monospace;
                         -fx-background-radius:8;-fx-cursor:hand;-fx-min-height:44;"/>
        </VBox>
      </HBox>
    </StackPane>
  </VBox>

</StackPane>